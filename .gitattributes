# Force LF line endings for scripts on all platforms
*.sh        text eol=lf
*.mjs       text eol=lf
*.js        text eol=lf
*.py        text eol=lf
*.hcl       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.env       text eol=lf
*.env.*     text eol=lf
Dockerfile  text eol=lf
